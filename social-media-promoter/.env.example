# Social Media Promoter - Environment Variables
# Copy this file to .env and fill in the values for platforms you want to use.

# ============================================================
# AWS Bedrock (required for content generation)
# ============================================================
AWS_REGION=us-east-1
# AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ============================================================
# X / Twitter (required for automated posting to X)
# Get keys at: https://developer.x.com/en/portal/dashboard
# ============================================================
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ============================================================
# Discord (required for automated posting to Discord)
# Create a webhook: Server Settings > Integrations > Webhooks
# ============================================================
DISCORD_WEBHOOK_URL=

# ============================================================
# Reddit (required for automated posting to Reddit)
# 1. Create a "script" app at: https://www.reddit.com/prefs/apps
# 2. OAuth2 is mandatory; PRAW handles the password flow automatically
# 3. Rate limit: 60 requests/min (PRAW manages this)
# 4. If 2FA is enabled, set REDDIT_PASSWORD=yourpassword:TOTP_TOKEN
#    (the TOTP token must be refreshed each time you run)
# ============================================================
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ============================================================
# Product Hunt (optional, for future API support)
# Get token at: https://www.producthunt.com/v2/oauth/applications
# Currently content is output for manual submission.
# ============================================================
# PRODUCTHUNT_API_TOKEN=

# ============================================================
# Xiaohongshu (optional, manual posting only)
# No API available. Content is generated for copy-paste.
# ============================================================
# XIAOHONGSHU_COOKIE=

# ============================================================
# Zhihu (optional, manual posting only)
# No API available. Content is generated for copy-paste.
# ============================================================
# ZHIHU_COOKIE=
